<!-- Displays a single Dinosaur's stats in a styled card -->
<!--The color will change based on gender-->
<div class="card p-2 m-2 @(Dinosaur.Gender == Gender.Male
             ? "dino-male"
             : (Dinosaur.Gender == Gender.Female
                 ? "dino-female"
                 : "dino-unknown"))">

    <!-- Basic identity -->
    <p>Species: @Dinosaur.Species</p>
    <p>Name: @Dinosaur.Name</p>

    <!-- Core stats -->
    <p>Health: @Dinosaur.Health</p>
    <p>Stamina: @Dinosaur.Stamina</p>
    <p>Oxygen: @Dinosaur.Oxygen</p>
    <p>Food: @Dinosaur.Food</p>
    <p>Water: @Dinosaur.Water</p>
    <p>Weight: @Dinosaur.Weight</p>
    <p>Melee: @Dinosaur.Melee</p>
</div>

@code {
    // Input parameter: the Dinosaur to display
    // This is passed in from the Page that calls this PartialView
    [Parameter]
    public DinosaurModel Dinosaur { get; set; } = default!;
}